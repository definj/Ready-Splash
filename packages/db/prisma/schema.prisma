generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  privacyMode  Boolean     @default(false)
  createdAt    DateTime    @default(now())
  accounts     Account[]
  watchlists   Watchlist[]
  sessions     Session[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id        String    @id @default(cuid())
  userId    String
  label     String
  broker    String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings  Holding[]
  createdAt DateTime  @default(now())
}

model Holding {
  id           String  @id @default(cuid())
  accountId    String
  ticker       String
  shares       Decimal @db.Decimal(18, 6)
  avgCostBasis Decimal @db.Decimal(18, 4)
  account      Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, ticker])
}

model Watchlist {
  id        String          @id @default(cuid())
  userId    String
  name      String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]
  createdAt DateTime        @default(now())
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  ticker      String
  notes       String?
  alertPrice  Decimal?  @db.Decimal(18, 4)
  sortOrder   Int       @default(0)
  addedAt     DateTime  @default(now())
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, ticker])
}
