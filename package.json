{
  "name": "ready-splash",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "db:generate": "npm run db:generate -w @ready-splash/db",
    "db:migrate": "npm run db:migrate -w @ready-splash/db",
    "db:push": "npm run db:push -w @ready-splash/db",
    "worker": "npm run start -w @ready-splash/worker",
    "worker:bull": "WORKER_MODE=bullmq npm run start -w @ready-splash/worker"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.4"
}
