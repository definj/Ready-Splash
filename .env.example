DATABASE_URL="postgresql://ready:ready@localhost:5432/ready_splash?schema=public"
REDIS_URL="redis://localhost:6379"
POLYGON_API_KEY=""
# St. Louis Fed API key for macro series (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=""
# When set to `1`, starts an in-process BullMQ worker for repeatable macro jobs (requires REDIS_URL)
BULL_WORKER=""
# `inline` (default) runs the repeatable job in the API when BULL_WORKER=1. `external` skips in-process
# execution so a separate process (e.g. `npm run worker`) can drive refresh via POST /internal/macro/refresh.
MACRO_QUEUE_MODE=""
# Shared secret for POST /internal/macro/refresh and POST /internal/yfinance-tick (Bearer token)
INTERNAL_CRON_SECRET=""
# Comma-separated origins for browser cookies + Socket.io (e.g. http://localhost:3000)
WEB_ORIGIN="http://localhost:3000"

# apps/worker — base URL of the Fastify API (defaults to http://127.0.0.1:4000)
# API_URL=http://127.0.0.1:4000
# WORKER_INTERVAL_MS=86400000
# WORKER_MODE=http (default) posts /internal/macro/refresh; WORKER_MODE=bullmq runs a BullMQ consumer (needs REDIS_URL)
# WORKER_MODE=bullmq

# When MACRO_QUEUE_MODE=external, set BULL_SCHEDULER=1 on the API to register the repeatable FRED job in Redis
# while running `npm run worker:bull` (or docker worker with WORKER_MODE=bullmq) for execution.
# BULL_SCHEDULER=1

# Next.js (apps/web) — copy to apps/web/.env.local
# NEXT_PUBLIC_API_URL=http://localhost:4000
